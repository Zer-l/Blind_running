<?xml version="1.0" encoding="utf-8"?>
<!--
    Release 默认全局拒绝 cleartext HTTP；下方 domain-config 单独允许"开发后端 IP"。
    上线时把 domain 改成正式服务器的 HTTPS 域名后，删除 domain-config 即可恢复全局 HTTPS。

    注意：<domain> 不支持 CIDR (如 192.168.0.0/16)，必须列具体 IP / 域名。
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <!-- 本地开发机 LAN IP（真机直连） -->
        <domain includeSubdomains="false">10.62.178.33</domain>
        <!-- 模拟器宿主映射 -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- 本机回环兜底 -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
