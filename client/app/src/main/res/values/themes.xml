<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- MainActivity（Compose 页面，使用系统 Material Light 不带 ActionBar） -->
    <style name="Theme.GuideRun" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        BlindActivity 高对比度主题：
        黑底白字 + 黄色 Primary，确保 WCAG AA 对比度 ≥ 4.5:1。
        继承 Theme.Material3.DayNight.NoActionBar，XML Fragment 可使用 MaterialButton 等组件。
    -->
    <style name="Theme.GuideRun.Blind" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blind_primary</item>
        <item name="colorOnPrimary">@color/blind_on_primary</item>
        <item name="colorSurface">@color/blind_surface</item>
        <item name="colorOnSurface">@color/blind_on_surface</item>
        <item name="android:windowBackground">@color/blind_background</item>
        <item name="android:textColor">@color/blind_on_background</item>
    </style>

    <!-- 视障端评价：5 个全屏宽卡片纵排，layout_weight=1 平均分配 -->
    <style name="BlindReview.Card" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginVertical">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="cardBackgroundColor">@color/blind_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/blind_on_surface</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="BlindReview.CardLabel" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/blind_on_surface</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
