<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- MainActivity（Compose 页面，使用系统 Material Light 不带 ActionBar） -->
    <style name="Theme.GuideRun" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        BlindActivity 高对比度主题：
        黑底白字 + 黄色 Primary，确保 WCAG AA 对比度 ≥ 4.5:1。
        继承 Theme.Material3.DayNight.NoActionBar，XML Fragment 可使用 MaterialButton 等组件。
    -->
    <style name="Theme.GuideRun.Blind" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blind_primary</item>
        <item name="colorOnPrimary">@color/blind_on_primary</item>
        <item name="colorSurface">@color/blind_surface</item>
        <item name="colorOnSurface">@color/blind_on_surface</item>
        <item name="android:windowBackground">@color/blind_background</item>
        <item name="android:textColor">@color/blind_on_background</item>
    </style>

    <!--
        视障端评价 5 个全屏宽卡片纵排。
        改 wrap_content + minHeight（ScrollView 内 layout_weight=1 不生效），
        颜色用 ?attr/blindXxx 适配 3 套对比度主题。
    -->
    <style name="BlindReview.Card" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/blind_touch_primary</item>
        <item name="android:layout_marginVertical">@dimen/blind_space_xs</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="cardBackgroundColor">?attr/blindSurface</item>
        <item name="cardCornerRadius">@dimen/blind_radius_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/blindOnSurface</item>
        <item name="strokeWidth">@dimen/blind_stroke_card</item>
    </style>

    <style name="BlindReview.CardLabel" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">@dimen/blind_touch_primary</item>
        <item name="android:padding">@dimen/blind_space_md</item>
        <item name="android:textColor">?attr/blindOnSurface</item>
        <item name="android:textSize">@dimen/blind_text_headline</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 视障端中断对话框：放大标题/正文/按钮字号，便于低视力用户操作 -->
    <style name="BlindInterruptDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/BlindInterruptDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/BlindInterruptDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/BlindInterruptDialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/BlindInterruptDialog.Button.Destructive</item>
        <item name="buttonBarNeutralButtonStyle">@style/BlindInterruptDialog.Button</item>
    </style>

    <style name="BlindInterruptDialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BlindInterruptDialog.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingExtra">6dp</item>
    </style>

    <style name="BlindInterruptDialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingHorizontal">20dp</item>
    </style>

    <style name="BlindInterruptDialog.Button.Destructive" parent="BlindInterruptDialog.Button">
        <item name="android:textColor">@android:color/holo_red_dark</item>
    </style>

    <!--
        视障端全屏确认对话框：用于破坏性操作（放弃创建 / 取消订单）。
        ThemeOverlay 合并到 Activity 当前主题（保留 3 套对比度主题的 ?attr/blindXxx 解析）；
        windowIsFloating=false → 占满屏幕；不显示遮罩。
    -->
    <style name="ThemeOverlay.GuideRun.BlindFullScreenDialog" parent="">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

</resources>
