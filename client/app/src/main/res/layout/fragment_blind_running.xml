<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blindBackground"
    android:fitsSystemWindows="true"
    android:keepScreenOn="true">

    <com.guiderun.app.ui.blind.widget.BlindPageHeader
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:headerTitle="@string/blind_running_title"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/blind_space_md">

            <!-- 自动暂停角标 -->
            <TextView
                android:id="@+id/tv_paused_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="@dimen/blind_space_md"
                android:accessibilityLiveRegion="polite"
                android:background="?attr/blindWarning"
                android:paddingHorizontal="@dimen/blind_space_md"
                android:paddingVertical="@dimen/blind_space_xs"
                android:text="@string/running_paused_label"
                android:textColor="?attr/blindOnPrimary"
                android:textSize="@dimen/blind_text_label"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.guiderun.app.ui.blind.widget.BlindMetricCard
                android:id="@+id/card_distance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_md"
                app:metricLabel="@string/blind_ui_running_distance_label"
                app:metricUnit="@string/blind_ui_running_distance_unit" />

            <com.guiderun.app.ui.blind.widget.BlindMetricCard
                android:id="@+id/card_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_md"
                app:metricLabel="@string/blind_ui_running_duration_label" />

            <com.guiderun.app.ui.blind.widget.BlindMetricCard
                android:id="@+id/card_pace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_md"
                app:metricLabel="@string/blind_ui_running_pace_label" />

            <!-- 关键状态文字：默认 GONE，仅"志愿者申请结束"等 assertive 事件显示 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:accessibilityLiveRegion="assertive"
                android:gravity="center"
                android:minHeight="@dimen/blind_touch_min"
                android:padding="@dimen/blind_space_md"
                android:textColor="?attr/blindOnSurface"
                android:textSize="@dimen/blind_text_body"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintBottom_toTopOf="@id/tv_action_hint" />

    <TextView
        android:id="@+id/tv_action_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:paddingHorizontal="@dimen/blind_space_md"
        android:paddingVertical="@dimen/blind_space_sm"
        android:text="@string/blind_hint_running_end"
        android:textColor="?attr/blindOnSurface"
        android:textSize="@dimen/blind_text_hint"
        app:layout_constraintBottom_toTopOf="@id/footer" />

    <com.guiderun.app.ui.blind.widget.BlindActionFooter
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/blind_space_md"
        android:paddingTop="0dp"
        android:paddingBottom="@dimen/blind_space_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:primaryLabel="@string/blind_ui_running_btn_end"
        app:primaryHint="@string/blind_hint_running_end" />

</androidx.constraintlayout.widget.ConstraintLayout>
