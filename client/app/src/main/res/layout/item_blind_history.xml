<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/blind_space_sm"
    app:cardBackgroundColor="?attr/blindSurface"
    app:cardCornerRadius="@dimen/blind_radius_card"
    app:cardElevation="0dp"
    app:strokeColor="?attr/blindPrimary"
    app:strokeWidth="@dimen/blind_stroke_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/blind_space_md">

        <TextView
            android:id="@+id/tv_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_xs"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_volunteer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_xs"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_hint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/blind_space_sm"
                android:textColor="?attr/blindPrimary"
                android:textSize="@dimen/blind_text_hint" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/blindPrimary"
                android:textSize="@dimen/blind_text_hint" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/blindPrimary"
                android:textSize="@dimen/blind_text_hint" />
        </LinearLayout>

        <!-- 补评按钮：仅已完成且自己未评时显示 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/blind_space_sm"
            android:minHeight="@dimen/blind_touch_min"
            android:paddingVertical="@dimen/blind_space_sm"
            android:text="@string/blind_history_btn_review"
            android:textColor="?attr/blindOnPrimary"
            android:textSize="@dimen/blind_text_body"
            android:visibility="gone"
            app:backgroundTint="?attr/blindPrimary"
            app:cornerRadius="@dimen/blind_radius_button" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
