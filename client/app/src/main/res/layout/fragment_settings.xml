<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blindBackground"
    android:fitsSystemWindows="true">

    <com.guiderun.app.ui.blind.widget.BlindPageHeader
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:headerTitle="@string/settings_title"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/blind_space_md">

        <!-- 快捷入口卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            app:cardBackgroundColor="?attr/blindSurface"
            app:cardCornerRadius="@dimen/blind_radius_card"
            app:cardElevation="0dp"
            app:strokeColor="?attr/blindPrimary"
            app:strokeWidth="@dimen/blind_stroke_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 我的资料 -->
                <LinearLayout
                    android:id="@+id/itemProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/blind_touch_min"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_edit_profile"
                        android:textColor="?attr/blindOnSurface"
                        android:textSize="@dimen/blind_text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:text="→"
                        android:textColor="?attr/blindPrimary"
                        android:textSize="@dimen/blind_text_headline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/blindOnSurface" />

                <!-- 紧急联系人 -->
                <LinearLayout
                    android:id="@+id/itemEmergencyContacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/blind_touch_min"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_emergency_contacts"
                        android:textColor="?attr/blindOnSurface"
                        android:textSize="@dimen/blind_text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:text="→"
                        android:textColor="?attr/blindPrimary"
                        android:textSize="@dimen/blind_text_headline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/blindOnSurface" />

                <!-- 跑步统计 -->
                <LinearLayout
                    android:id="@+id/itemBlindStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/blind_touch_min"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_stats_title"
                        android:textColor="?attr/blindOnSurface"
                        android:textSize="@dimen/blind_text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:text="→"
                        android:textColor="?attr/blindPrimary"
                        android:textSize="@dimen/blind_text_headline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/blindOnSurface" />

                <!-- 无障碍设置 -->
                <LinearLayout
                    android:id="@+id/itemAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/blind_touch_min"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_voice"
                        android:textColor="?attr/blindOnSurface"
                        android:textSize="@dimen/blind_text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:text="→"
                        android:textColor="?attr/blindPrimary"
                        android:textSize="@dimen/blind_text_headline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/blindOnSurface" />

                <!-- 关于 -->
                <LinearLayout
                    android:id="@+id/itemAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/blind_touch_min"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_about"
                        android:textColor="?attr/blindOnSurface"
                        android:textSize="@dimen/blind_text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:text="→"
                        android:textColor="?attr/blindPrimary"
                        android:textSize="@dimen/blind_text_headline" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/blindOnSurface" />

                <!-- 退出登录（破坏性操作，红色文字） -->
                <com.guiderun.app.ui.blind.widget.BlindLongPressGestureView
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/blind_touch_min"
                    android:paddingHorizontal="@dimen/blind_space_md"
                    android:paddingVertical="@dimen/blind_space_sm"
                    android:text="@string/blind_ui_home_btn_logout"
                    android:textColor="?attr/blindWarning"
                    android:textSize="@dimen/blind_text_body"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
