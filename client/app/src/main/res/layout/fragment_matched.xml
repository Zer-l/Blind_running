<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blindBackground"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/blind_space_lg">

        <!-- 页面顶部：标题 + 实时状态 -->
        <com.guiderun.app.ui.blind.widget.BlindPageHeader
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            app:headerTitle="@string/matched_title" />

        <!-- 志愿者信息卡 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_volunteer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            app:cardBackgroundColor="?attr/blindSurface"
            app:cardCornerRadius="@dimen/blind_radius_card"
            app:cardElevation="0dp"
            app:strokeColor="?attr/blindPrimary"
            app:strokeWidth="@dimen/blind_stroke_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/blind_space_md">

                <TextView
                    android:id="@+id/tv_volunteer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/blind_space_xs"
                    android:gravity="center"
                    android:textColor="?attr/blindOnSurface"
                    android:textSize="@dimen/blind_text_headline"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_volunteer_rating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="?attr/blindPrimary"
                    android:textSize="@dimen/blind_text_label" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 实时状态描述（assertive，关键状态强制朗读） -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            android:accessibilityLiveRegion="assertive"
            android:gravity="center"
            android:minHeight="@dimen/blind_touch_min"
            android:padding="@dimen/blind_space_md"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_body" />

        <!-- 操作底部：仅 MET 状态可用 -->
        <com.guiderun.app.ui.blind.widget.BlindActionFooter
            android:id="@+id/footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:primaryLabel="@string/blind_ui_matched_btn_confirm"
            app:primaryHint="@string/blind_hint_matched_waiting" />

    </LinearLayout>
</ScrollView>
