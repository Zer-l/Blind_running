<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:id="@+id/tv_metric_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:textColor="?attr/blindOnSurface"
        android:textSize="@dimen/blind_text_label" />

    <TextView
        android:id="@+id/tv_metric_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:textColor="?attr/blindPrimary"
        android:textSize="@dimen/blind_text_display"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_metric_unit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:textColor="?attr/blindOnSurface"
        android:textSize="@dimen/blind_text_label" />

</merge>
