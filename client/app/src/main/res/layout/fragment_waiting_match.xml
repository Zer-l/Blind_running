<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blind_background"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="@string/waiting_match_title"
        android:textColor="@color/blind_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- 等待动画（循环进度条） -->
    <ProgressBar
        android:id="@+id/progress_waiting"
        style="@android:style/Widget.ProgressBar.Large"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:importantForAccessibility="no"
        android:indeterminateTint="@color/blind_primary" />

    <!-- 已等待时长 -->
    <TextView
        android:id="@+id/tv_elapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:accessibilityLiveRegion="polite"
        android:gravity="center"
        android:textColor="@color/blind_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 情绪曲线等待提示语（自动更新） -->
    <TextView
        android:id="@+id/tv_waiting_message"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:accessibilityLiveRegion="polite"
        android:gravity="center"
        android:padding="16dp"
        android:textColor="@color/blind_on_background"
        android:textSize="18sp" />

    <!-- 手势提示 / 取消倒计时状态 -->
    <TextView
        android:id="@+id/tv_cancel_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:accessibilityLiveRegion="assertive"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/waiting_match_gesture_hint"
        android:textColor="@color/blind_warning"
        android:textSize="16sp" />

</LinearLayout>
