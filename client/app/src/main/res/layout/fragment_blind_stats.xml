<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blind_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="16dp"
            android:text="跑步统计"
            android:textColor="@color/blind_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="invisible" />

        <!-- 统计卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/blind_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/blind_primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 完成次数 -->
                <TextView
                    android:id="@+id/tvTotalRuns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="总计跑步：0 次"
                    android:textColor="@color/blind_on_surface"
                    android:textSize="18sp" />

                <!-- 总距离 -->
                <TextView
                    android:id="@+id/tvTotalDistance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="总距离：0 公里"
                    android:textColor="@color/blind_on_surface"
                    android:textSize="18sp" />

                <!-- 总时长 -->
                <TextView
                    android:id="@+id/tvTotalDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="总时长：0 分钟"
                    android:textColor="@color/blind_on_surface"
                    android:textSize="18sp" />

                <!-- 本月跑步 -->
                <TextView
                    android:id="@+id/tvCurrentMonthRuns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="本月跑步：0 次"
                    android:textColor="@color/blind_on_surface"
                    android:textSize="18sp" />

                <!-- 平均时长（隐藏） -->
                <TextView
                    android:id="@+id/tvAverageDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/blind_on_surface"
                    android:textSize="18sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
