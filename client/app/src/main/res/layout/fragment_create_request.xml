<?xml version="1.0" encoding="utf-8"?>
<!--
    UI-3 发起跑步请求（EditRequest 已并入本页）。

    结构：
      [BlindPageHeader]   顶部独立标题
      [divider_top]       上分割线
      [ScrollView]        可滚动表单区
        - 集合地点（TextInputLayout，可手改/语音改）
        - 时长 4 按钮 (30/60/90/120，大字号档位自适应竖排)
        - 备注（TextInputLayout）
        - tv_error
      [divider_bottom]    下分割线
      [tv_action_hint]    长按手势提示（置于操作区顶部，同时覆盖语音按钮与确认按钮）
      [btn_voice_input]   语音输入大按钮（常驻，不被 ScrollView 内容推走，大字号下无需滚动）
      [footer]            吸底主操作（长按 2s+5s 提交）
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blindBackground"
    android:fitsSystemWindows="true">

    <!-- 顶部独立标题区 -->
    <com.guiderun.app.ui.blind.widget.BlindPageHeader
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:headerTitle="@string/create_request_title"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 滚动区上分割线 -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/blind_space_md">

            <!-- 集合地点 标签 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_sm"
                android:text="@string/edit_request_location_label"
                android:textColor="?attr/blindOnSurface"
                android:textSize="@dimen/blind_text_label"
                android:textStyle="bold" />

            <!-- 集合地点 输入框（无 endIcon，统一走下方独立语音按钮） -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_location"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_lg"
                android:hint="@string/edit_request_location_hint"
                android:textColorHint="?attr/blindOnSurface"
                app:boxStrokeColor="@color/blind_input_stroke"
                app:boxStrokeWidth="2dp"
                app:boxStrokeWidthFocused="3dp"
                app:hintTextColor="?attr/blindOnSurface">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="?attr/blindOnSurface"
                    android:textColorHint="?attr/blindOnSurface"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/blind_text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 时长选择标签 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_sm"
                android:text="@string/create_request_duration_label"
                android:textColor="?attr/blindOnSurface"
                android:textSize="@dimen/blind_text_label"
                android:textStyle="bold" />

            <!-- 时长 4 按钮 -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_lg"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_30min"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/blind_touch_min"
                    android:paddingVertical="@dimen/blind_space_sm"
                    android:contentDescription="@string/create_request_duration_30"
                    android:maxLines="1"
                    android:text="@string/create_request_duration_30"
                    android:textColor="?attr/blindOnSurface"
                    android:textSize="@dimen/blind_text_body"
                    app:autoSizeMaxTextSize="@dimen/blind_text_body"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/blindOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_60min"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/blind_touch_min"
                    android:paddingVertical="@dimen/blind_space_sm"
                    android:contentDescription="@string/create_request_duration_60"
                    android:maxLines="1"
                    android:text="@string/create_request_duration_60"
                    android:textColor="?attr/blindOnSurface"
                    android:textSize="@dimen/blind_text_body"
                    app:autoSizeMaxTextSize="@dimen/blind_text_body"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/blindOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_90min"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/blind_touch_min"
                    android:paddingVertical="@dimen/blind_space_sm"
                    android:contentDescription="@string/create_request_duration_90"
                    android:maxLines="1"
                    android:text="@string/create_request_duration_90"
                    android:textColor="?attr/blindOnSurface"
                    android:textSize="@dimen/blind_text_body"
                    app:autoSizeMaxTextSize="@dimen/blind_text_body"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/blindOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_120min"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="@dimen/blind_touch_min"
                    android:paddingVertical="@dimen/blind_space_sm"
                    android:contentDescription="@string/create_request_duration_120"
                    android:maxLines="1"
                    android:text="@string/create_request_duration_120"
                    android:textColor="?attr/blindOnSurface"
                    android:textSize="@dimen/blind_text_body"
                    app:autoSizeMaxTextSize="@dimen/blind_text_body"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeTextType="uniform"
                    app:strokeColor="?attr/blindOnSurface" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- 备注 标签 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_sm"
                android:text="@string/create_request_notes_label"
                android:textColor="?attr/blindOnSurface"
                android:textSize="@dimen/blind_text_label"
                android:textStyle="bold" />

            <!-- 备注输入（无 endIcon） -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_notes"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/blind_space_lg"
                android:hint="@string/create_request_notes_hint"
                android:textColorHint="?attr/blindOnSurface"
                app:boxStrokeColor="@color/blind_input_stroke"
                app:boxStrokeWidth="2dp"
                app:boxStrokeWidthFocused="3dp"
                app:hintTextColor="?attr/blindOnSurface">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="2"
                    android:textColor="?attr/blindOnSurface"
                    android:textColorHint="?attr/blindOnSurface"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/blind_text_body" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 错误提示（默认 GONE，assertive） -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:accessibilityLiveRegion="assertive"
                android:background="?attr/blindWarning"
                android:padding="@dimen/blind_space_md"
                android:textColor="@color/white"
                android:textSize="@dimen/blind_text_body"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- 滚动区下分割线 -->
    <View
        android:id="@+id/divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/blindPrimary"
        app:layout_constraintBottom_toTopOf="@id/tv_action_hint" />

    <!-- 手势提示区（置于操作区顶部，统领下方语音 + 确认两个按钮） -->
    <TextView
        android:id="@+id/tv_action_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:paddingHorizontal="@dimen/blind_space_md"
        android:paddingVertical="@dimen/blind_space_sm"
        android:text="@string/blind_hint_create_request_primary"
        android:textColor="?attr/blindOnSurface"
        android:textSize="@dimen/blind_text_hint"
        app:layout_constraintBottom_toTopOf="@id/btn_voice_input" />

    <!-- 语音输入大按钮（移出 ScrollView 常驻底部，避免大字号档位被表单内容推走需要滚动才能触达） -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_voice_input"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/blind_space_md"
        android:layout_marginBottom="@dimen/blind_space_sm"
        android:background="@drawable/bg_blind_voice_button"
        android:contentDescription="@string/blind_ui_create_request_voice_input_desc"
        android:minHeight="@dimen/blind_touch_primary"
        android:paddingHorizontal="@dimen/blind_space_md"
        android:paddingVertical="@dimen/blind_space_md"
        android:text="@string/blind_ui_create_request_voice_input"
        android:textColor="?attr/blindOnPrimary"
        android:textSize="@dimen/blind_text_headline"
        android:textStyle="bold"
        app:cornerRadius="@dimen/blind_radius_button"
        app:icon="@drawable/ic_mic"
        app:iconGravity="textStart"
        app:iconTint="?attr/blindOnPrimary"
        app:layout_constraintBottom_toTopOf="@id/footer" />

    <!-- 吸底操作热区（无次按钮 — EditRequest 已并入本页） -->
    <com.guiderun.app.ui.blind.widget.BlindActionFooter
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/blind_space_md"
        android:paddingTop="0dp"
        android:paddingBottom="@dimen/blind_space_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:primaryLabel="@string/blind_ui_create_request_btn_primary"
        app:primaryHint="@string/blind_hint_create_request_primary" />

</androidx.constraintlayout.widget.ConstraintLayout>
