<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/blind_space_sm"
    app:cardBackgroundColor="?attr/blindSurface"
    app:cardCornerRadius="@dimen/blind_radius_card"
    app:cardElevation="0dp"
    app:strokeColor="?attr/blindPrimary"
    app:strokeWidth="@dimen/blind_stroke_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/blind_space_md">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_headline"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRelationship"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/blind_space_xs"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_label" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/blind_space_xs"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/blind_space_sm"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/blind_touch_min"
                android:paddingHorizontal="@dimen/blind_space_md"
                android:text="@string/blind_ui_emergency_contact_btn_edit"
                android:textColor="?attr/blindPrimary"
                android:textSize="@dimen/blind_text_label" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/blind_touch_min"
                android:paddingHorizontal="@dimen/blind_space_md"
                android:text="@string/blind_ui_emergency_contact_btn_delete"
                android:textColor="?attr/blindError"
                android:textSize="@dimen/blind_text_label" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
