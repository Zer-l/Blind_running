<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blindBackground"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/blind_space_lg">

        <!-- 页面顶部：标题 -->
        <com.guiderun.app.ui.blind.widget.BlindPageHeader
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            app:headerTitle="@string/blind_review_title" />

        <!-- 本次跑步摘要 -->
        <TextView
            android:id="@+id/tv_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/blind_space_md"
            android:gravity="center"
            android:textColor="?attr/blindOnSurface"
            android:textSize="@dimen/blind_text_body" />

        <!-- 5 张评分卡（垂直） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_1"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_1_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_1_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_2"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_2_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_2_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_3"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_3_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_3_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_4"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_4_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_4_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_5"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_5_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_5_label" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 操作底部：主按钮提交（长按 2s+5s），次按钮跳过 -->
        <com.guiderun.app.ui.blind.widget.BlindActionFooter
            android:id="@+id/footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/blind_space_md"
            app:primaryLabel="@string/blind_ui_blind_review_btn_submit"
            app:primaryHint="@string/blind_hint_blind_review_submit"
            app:secondaryLabel="@string/blind_ui_blind_review_btn_skip" />

    </LinearLayout>
</ScrollView>
