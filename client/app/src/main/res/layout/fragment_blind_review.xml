<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blind_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/blind_review_title"
        android:textColor="@color/blind_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/blind_on_surface"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="@string/blind_review_gesture_hint"
        android:textColor="@color/blind_on_background"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_1"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_1_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_1_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_2"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_2_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_2_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_3"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_3_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_3_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_4"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_4_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_4_label" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rating_5"
            style="@style/BlindReview.Card"
            android:contentDescription="@string/blind_review_rating_5_desc">

            <TextView
                style="@style/BlindReview.CardLabel"
                android:text="@string/blind_review_rating_5_label" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
