<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== 网络 ===== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ===== 位置（运行时申请） ===== -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Android 10+ 后台持续定位（跑步轨迹录制） -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ===== 语音识别（运行时申请） ===== -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ===== 通知（Android 13+ 运行时申请，前台服务必需） ===== -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ===== 震动（普通权限，自动授予） ===== -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ===== 电话（语音通话，运行时申请） ===== -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- ===== 讯飞 MSC SDK 写存储（仅 Android 9 以下，用于缓存识别资源） ===== -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- ===== 前台服务（跑步轨迹录制） ===== -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- ===== 保持 CPU 唤醒（前台服务持续运行） ===== -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ===== Android 11+ 包可见性：声明需要查询的服务 ===== -->
    <queries>
        <!-- TTS 语音播报 -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <!-- 语音识别 -->
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GuideRun">

        <!-- 高德地图 API Key -->
        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="${AMAP_KEY}" />

        <!-- 主入口：Compose 导航（登录 / 角色选择 / 首页） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GuideRun">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 视障端：单 Activity + Navigation Fragment，固定竖屏保证 TalkBack 稳定性 -->
        <activity
            android:name=".ui.blind.BlindActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.GuideRun.Blind" />

        <!-- 志愿者端位置上报前台服务 -->
        <service
            android:name=".service.LocationUpdateService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- 跑步轨迹录制前台服务 -->
        <service
            android:name=".service.VolunteerRunTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />
        <service
            android:name=".service.BlindRunTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

</manifest>
