# =============================================================================
# Release 签名配置模板
#
# 步骤：
# 1. 在 client/ 目录执行（生成 .jks 密钥库）：
#
#      keytool -genkeypair -v \
#        -keystore keystore/release.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 \
#        -alias guiderun
#
#    交互输入时设置 store 密码、姓名/组织等信息（用于证书）。
#
# 2. 拷贝本文件为 client/keystore.properties 并填入实际值：
#
#      cp keystore.properties.example keystore.properties
#
# 3. 编辑 client/keystore.properties，填入实际密码与别名。
#
# client/keystore.properties 与 keystore/*.jks 已在 .gitignore，
# 绝对不会被提交到仓库。务必本地备份密钥库——丢失即无法发布同包名后续版本。
# =============================================================================

# .jks 路径（相对 client/ 目录）
storeFile=keystore/release.jks

# 上一步 keytool 交互时设置的 store 密码
storePassword=CHANGE_ME

# 别名（必须与 keytool -alias 一致）
keyAlias=guiderun

# 别名密码（如未单独设置则与 storePassword 相同）
keyPassword=CHANGE_ME
