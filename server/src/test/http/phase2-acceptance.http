### ========================================

### 5.1 查询订单 1 的完整事件流（如果有此接口）
GET {{baseUrl}}/run-requests/{{requestId}}
Authorization: Bearer {{blindToken}}

> {%
    client.log("订单 1 完整数据: " + JSON.stringify(response.body.data, null, 2));
%}

### ========================================
### 验收场景 6：provisioning 拦截
### ========================================

### 6.1 新手机号登录（自动创建 PENDING_ROLE 账号）
# @name loginPending
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "phone": "{{pendingPhone}}",
  "smsCode": "{{smsCode}}"
}

> {%
    client.global.set("pendingToken", response.body.data.accessToken);
    client.test("provisioningStatus 为 PENDING_ROLE", function() {
        client.assert(response.body.data.provisioningStatus === "PENDING_ROLE",
            "新账号 provisioningStatus 应为 PENDING_ROLE，实际：" + response.body.data.provisioningStatus);
    });
%}

### 6.2 PENDING_ROLE 账号调用业务接口（应 403 PROVISIONING_INCOMPLETE）
POST {{baseUrl}}/run-requests
Content-Type: application/json
Authorization: Bearer {{pendingToken}}
Idempotency-Key: phase2-pending-{{$uuid}}

{
  "expectedDurationMinutes": 30,
  "meetingLocation": { "lat": 39.9042, "lng": 116.4074, "description": "测试" }
}

> {%
    client.test("PENDING_ROLE 用户发起请求应返回 403 PROVISIONING_INCOMPLETE", function() {
        client.assert(response.status === 403, "应返回 403，实际：" + response.status);
        client.assert(response.body.errorCode === "PROVISIONING_INCOMPLETE",
            "errorCode 应为 PROVISIONING_INCOMPLETE，实际：" + response.body.errorCode);
    });
%}

### 6.3 PENDING_ROLE 账号调用 PATCH /users/me 设置角色（白名单，应放行）
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{pendingToken}}

{
  "roles": ["BLIND_RUNNER"]
}

> {%
    client.test("设置角色应成功，provisioningStatus 升级为 ACTIVE", function() {
        client.assert(response.status === 200, "应返回 200，实际：" + response.status);
        client.assert(response.body.data.provisioningStatus === "ACTIVE",
            "设置角色后 provisioningStatus 应为 ACTIVE，实际：" + response.body.data.provisioningStatus);
    });
%}

### 6.4 升级后再次发起请求（应成功）
# @name createRequest6
POST {{baseUrl}}/run-requests
Content-Type: application/json
Authorization: Bearer {{pendingToken}}
Idempotency-Key: phase2-pending-active-{{$uuid}}

{
  "expectedDurationMinutes": 30,
  "meetingLocation": { "lat": 39.9042, "lng": 116.4074, "description": "测试" }
}

> {%
    client.test("角色设置后应能正常发起请求", function() {
        client.assert(response.status === 200 || response.status === 201, "应返回 200/201，实际：" + response.status);
        client.assert(response.body.data.status === "MATCHING", "状态应为 MATCHING");
    });
    client.global.set("requestId6", response.body.data.id);
%}

### 6.5 志愿者 B 接 requestId6
POST {{baseUrl}}/run-requests/{{requestId6}}/accept
Authorization: Bearer {{volunteerBToken}}

> {%
    client.test("志愿者接单成功，状态为 ACCEPTED", function() {
        client.assert(response.body.data.status === "ACCEPTED", "应为 ACCEPTED");
    });
%}