### ========================================
### 4. 推送实时指标
### ========================================

### 4.1 中期指标
POST {{baseUrl}}/run-requests/{{requestId}}/peer-metrics
Content-Type: application/json
Authorization: Bearer {{volunteerToken}}

{
  "totalDistanceMeters": 1500,
  "totalDurationSeconds": 399,
  "currentPaceSeconds": 266,
  "avgPaceSeconds": 266
}

> {%
    client.test("中期指标推送成功", function() {
        client.assert(response.status === 200, "HTTP 200");
    });
%}

### ========================================
### 5. 结束跑步（协商式：志愿者申请 → 视障端确认）
### ========================================

### 5.1 志愿者申请结束跑步
POST {{baseUrl}}/run-requests/{{requestId}}/request-end-run
Authorization: Bearer {{volunteerToken}}

> {%
    client.test("志愿者申请结束跑步成功", function() {
        client.assert(response.status === 200, "HTTP 200");
    });
    client.log("志愿者已申请结束跑步");
%}

### 5.2 视障端确认结束跑步
POST {{baseUrl}}/run-requests/{{requestId}}/end-run
Content-Type: application/json
Authorization: Bearer {{blindToken}}

{
  "actualDistanceMeters": 2999,
  "actualDurationSeconds": 798,
  "avgPaceSeconds": 266
}

> {%
    client.test("结束跑步成功", function() {
        client.assert(response.status === 200, "HTTP 200");
        client.assert(response.body.data.status === "FINISHED", "状态应为 FINISHED");
    });
    client.log("========================================");
    client.log("跑步结束！");
    client.log("总距离: 2999米");
    client.log("总时长: 798秒");
    client.log("平均配速: 266秒/公里");
    client.log("轨迹点数: 797");
    client.log("========================================");
%}

### ========================================
### 6. 查询轨迹验证（应返回 2 条: VOLUNTEER + BLIND）
### ========================================

### 6.1 查询轨迹
GET {{baseUrl}}/run-requests/{{requestId}}/tracks
Authorization: Bearer {{volunteerToken}}

> {%
    client.test("轨迹查询成功", function() {
        client.assert(response.status === 200, "HTTP 200");
        client.assert(response.body.data !== undefined, "应返回轨迹数据");
    });
    if (response.body.data && response.body.data.items) {
        client.log("轨迹记录数: " + response.body.data.items.length + " (期望: 2条 - VOLUNTEER + BLIND)");
        response.body.data.items.forEach(function(track) {
            client.log("  role=" + track.role
                + " | 点数=" + track.pointCount
                + " | 距离=" + track.totalDistanceMeters + "m"
                + " | 时长=" + track.totalDurationSeconds + "s"
                + " | 配速=" + track.avgPaceSeconds + "s/km");
        });
    }
%}

### 6.2 查询订单详情
GET {{baseUrl}}/run-requests/{{requestId}}
Authorization: Bearer {{volunteerToken}}

> {%
    client.test("订单已结束", function() {
        client.assert(response.status === 200, "HTTP 200");
        client.assert(response.body.data.status === "FINISHED", "状态应为 FINISHED");
    });
    client.log("订单状态: " + response.body.data.status);
    client.log("实际距离: " + response.body.data.actualDistanceMeters + "米");
    client.log("实际时长: " + response.body.data.actualDurationSeconds + "秒");
    client.log("平均配速: " + response.body.data.avgPaceSeconds + "秒/公里");
%}
