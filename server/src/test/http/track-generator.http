    client.test("结束跑步成功", function() {
        client.assert(response.status === 200, "HTTP 200");
        client.assert(response.body.data.status === "FINISHED", "状态应为 FINISHED");
    });
    client.log("========================================");
    client.log("跑步结束！");
    client.log("总距离: 3000米 (7.5圈)");
    client.log("总时长: 30分钟 (1800秒)");
